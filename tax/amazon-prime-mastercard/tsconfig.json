{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "es2020"
    ],
    "types": [
      "google-apps-script"
    ],
    "rootDir": "src",
    "outDir": "build",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
